generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
}

enum AgeTier {
  ADULT
  YOUTH
  CHILD
}

enum SeasonType {
  WINTER
  SUMMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  BUMPED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SubscriptionStatus {
  UNPAID
  PAID
  OVERDUE
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_NIGHTS
}

enum ChoreStatus {
  SUGGESTED
  CONFIRMED
  COMPLETED
}

model Member {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  phone        String?
  role         Role     @default(MEMBER)
  active       Boolean  @default(true)
  xeroContactId String?

  bookings       Booking[]
  subscriptions  MemberSubscription[]
  promoRedemptions PromoRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([xeroContactId])
}

model MemberSubscription {
  id           String             @id @default(cuid())
  memberId     String
  member       Member             @relation(fields: [memberId], references: [id])
  seasonYear   Int
  status       SubscriptionStatus @default(UNPAID)
  xeroInvoiceId String?
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, seasonYear])
  @@index([memberId])
}

model Season {
  id        String     @id @default(cuid())
  name      String
  type      SeasonType
  startDate DateTime
  endDate   DateTime
  active    Boolean    @default(true)

  rates SeasonRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeasonRate {
  id               String  @id @default(cuid())
  seasonId         String
  season           Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  ageTier          AgeTier
  isMember         Boolean
  pricePerNightCents Int

  @@unique([seasonId, ageTier, isMember])
  @@index([seasonId])
}

model Booking {
  id          String        @id @default(cuid())
  memberId    String
  member      Member        @relation(fields: [memberId], references: [id])
  checkIn     DateTime
  checkOut    DateTime
  status      BookingStatus @default(PENDING)
  totalPriceCents  Int
  discountCents    Int       @default(0)
  finalPriceCents  Int
  hasNonMembers    Boolean   @default(false)
  nonMemberHoldUntil DateTime?
  notes       String?

  guests      BookingGuest[]
  payment     Payment?
  choreAssignments ChoreAssignment[]
  promoRedemption  PromoRedemption?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([checkIn, checkOut])
  @@index([status])
}

model BookingGuest {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  ageTier    AgeTier
  isMember   Boolean  @default(false)
  memberId   String?
  priceCents Int

  choreAssignments ChoreAssignment[]

  @@index([bookingId])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id])
  amountCents           Int
  stripePaymentIntentId String?       @unique
  stripePaymentMethodId String?
  xeroInvoiceId         String?       @unique
  status                PaymentStatus @default(PENDING)
  refundedAmountCents   Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

model PromoCode {
  id                String    @id @default(cuid())
  code              String    @unique
  description       String?
  type              PromoType
  valueCents        Int?
  percentOff        Int?
  freeNights        Int?
  maxRedemptions    Int?
  currentRedemptions Int      @default(0)
  validFrom         DateTime?
  validUntil        DateTime?
  membersOnly       Boolean   @default(false)
  singleUse         Boolean   @default(false)
  active            Boolean   @default(true)

  redemptions PromoRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id])
  memberId    String
  member      Member    @relation(fields: [memberId], references: [id])
  discountCents Int

  createdAt DateTime @default(now())

  @@index([promoCodeId])
  @@index([memberId])
}

model ChoreTemplate {
  id                String  @id @default(cuid())
  name              String
  description       String?
  recommendedPeople Int     @default(2)
  minAge            Int     @default(10)
  sortOrder         Int     @default(0)
  active            Boolean @default(true)

  assignments ChoreAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChoreAssignment {
  id              String       @id @default(cuid())
  choreTemplateId String
  choreTemplate   ChoreTemplate @relation(fields: [choreTemplateId], references: [id])
  bookingId       String
  booking         Booking      @relation(fields: [bookingId], references: [id])
  bookingGuestId  String?
  bookingGuest    BookingGuest? @relation(fields: [bookingGuestId], references: [id])
  date            DateTime
  status          ChoreStatus  @default(SUGGESTED)

  @@index([date])
  @@index([bookingId])
}

model CancellationPolicy {
  id               String @id @default(cuid())
  daysBeforeStay   Int
  refundPercentage Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([daysBeforeStay])
}

model XeroToken {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  tenantId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
